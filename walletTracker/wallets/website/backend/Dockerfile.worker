# separate dockerfile for the scanner worker so it stays lean.
# doesn't need fastapi, uvicorn, pandas, matplotlib etc — just pymongo + httpx
FROM python:3.13-slim

WORKDIR /app

COPY requirements-worker.txt .
RUN pip install --no-cache-dir -r requirements-worker.txt

COPY . .

# the scanner runs forever (continuous loop), so it works as a DO worker
CMD ["python", "scripts/profitabilityScanner.py"]

